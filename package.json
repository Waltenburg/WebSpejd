{
  "scripts": {
    "build:test": "tsc --project tsconfig.test.json",
    "build": "tsc --project tsconfig.deployed.json",
    "test": "mocha",
    "test:watch": "mocha --watch",
    "testAfterBuild": "npm run build:test && npm run test",
    "clean:deployed": "rimraf --glob Deployed/**/*.js",
    "clean:test": "rimraf --glob Test/**/*.js",
    "clean": "npm run clean:deployed && npm run clean:test"
  },
  "devDependencies": {
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.15.10",
    "chai": "^5.1.2",
    "mocha": "^11.0.1",
    "ts-node": "^10.9.1",
    "typescript": "latest"
  },
  "dependencies": {
    "@types/plotly.js": "^2.12.18",
    "rimraf": "^6.0.1"
  }
}
