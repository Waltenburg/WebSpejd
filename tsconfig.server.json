{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "target",
        "rootDir": "./src",
        "module": "commonjs",
        "target": "es2020",
        "esModuleInterop": true,
    },
    "include": ["./src/**/*.ts"],
    "exclude": [
        "node_modules",
        "src/**/*.spec.ts",
        "src/clientFiles/**"
    ]
}