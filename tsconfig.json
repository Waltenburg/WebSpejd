{
    "compilerOptions": {
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": false,
        "isolatedModules": false,
        "importsNotUsedAsValues": "remove",
        "sourceMap": true,
        // "esModuleInterop": true,
        // "strictNullChecks": true, // Should be enabled, but causes too many issues right now
    },
    "include": [ "src" ],
    "exclude": [ "node_modules", "src/clientFiles", "src/**/*.spec.ts" ]
}
